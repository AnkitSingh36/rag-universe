cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data (don't commit large files)
data/
datasets/
*.csv
*.pkl
*.pickle
*.parquet

# Models (too large)
models/
*.bin
*.pt
*.pth

# Logs
*.log
logs/

# Environment variables
.env
.env.local
.env.*.local

# Test coverage
.coverage
htmlcov/
.pytest_cache/

# OS
.DS_Store
Thumbs.db

# Build artifacts
dist/
build/
*.egg-info/
EOF